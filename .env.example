# App
LICENSEDESK_DEBUG=true
LICENSEDESK_SECRET_KEY=change-me-in-production

# Database
LICENSEDESK_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/license_desk

# Redis
LICENSEDESK_REDIS_URL=redis://localhost:6379/0

# JWT
LICENSEDESK_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# S3 Storage (optional — if disabled, local filesystem is used)
LICENSEDESK_S3_ENABLED=false
LICENSEDESK_S3_ENDPOINT_URL=https://s3.amazonaws.com
LICENSEDESK_S3_ACCESS_KEY=
LICENSEDESK_S3_SECRET_KEY=
LICENSEDESK_S3_BUCKET=licensedesk
LICENSEDESK_S3_REGION=us-east-1
LICENSEDESK_S3_PUBLIC_URL=

# SMTP (optional — set SMTP_ENABLED=true to activate email notifications)
LICENSEDESK_SMTP_ENABLED=false
LICENSEDESK_SMTP_HOST=smtp.example.com
LICENSEDESK_SMTP_PORT=587
LICENSEDESK_SMTP_USER=
LICENSEDESK_SMTP_PASSWORD=
LICENSEDESK_SMTP_FROM_EMAIL=noreply@example.com
LICENSEDESK_SMTP_FROM_NAME=LicenseDesk
LICENSEDESK_SMTP_USE_TLS=true

# Keycloak OIDC (optional — set KEYCLOAK_ENABLED=true to activate)
LICENSEDESK_KEYCLOAK_ENABLED=false
LICENSEDESK_KEYCLOAK_BASE_URL=http://localhost:8080
LICENSEDESK_KEYCLOAK_PUBLIC_URL=http://localhost:8080
LICENSEDESK_KEYCLOAK_REALM=license-desk
LICENSEDESK_KEYCLOAK_CLIENT_ID=license-desk-app
LICENSEDESK_KEYCLOAK_CLIENT_SECRET=your-client-secret
LICENSEDESK_KEYCLOAK_REDIRECT_URI=http://localhost:8000/api/auth/oidc/callback
LICENSEDESK_KEYCLOAK_FRONTEND_URL=http://localhost:5173
